# Copy to `.env` and adjust. docker-compose reads this file automatically.
# Sensible defaults are baked into docker-compose.yml, so the stack also runs
# without a .env file — but you SHOULD set a real SECRET_KEY for anything public.

# --- Postgres ---
POSTGRES_DB=wikiverse
POSTGRES_USER=wikiverse
POSTGRES_PASSWORD=wikiverse

# --- Django ---
# Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=true

# --- Frontend ---
VITE_API_URL=http://localhost:8000/api
